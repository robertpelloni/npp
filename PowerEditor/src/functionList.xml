<NotepadPlus>
    <functionList>
        <parser id="cpp" displayName="C++" commentExpr="//.*|/\*.*?\*/">
            <function mainExpr="(?:[a-zA-Z_][a-zA-Z0-9_*&amp;]*\s+)+([a-zA-Z_][a-zA-Z0-9_]*)\s*\([^)]*\)\s*\{" />
        </parser>
        <parser id="python" displayName="Python" commentExpr="#.*">
            <function mainExpr="def\s+([a-zA-Z_][a-zA-Z0-9_]*)\s*\(" />
        </parser>
    </functionList>
</NotepadPlus>
